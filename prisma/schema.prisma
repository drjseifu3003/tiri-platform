// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  STAFF
}

enum MediaType {
  IMAGE
  VIDEO
}

enum GuestCategory {
  GENERAL
  BRIDE_GUEST
  GROOM_GUEST
}

enum InvitationChannel {
  WHATSAPP
  TELEGRAM
  SMS
}

enum EventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum BookingRequestStatus {
  NEW
  HANDLED
  CANCELLED
}

//////////////////////////////////////////////////////
// STUDIO (Multi-Tenant Root)
//////////////////////////////////////////////////////

model Studio {
  id            String   @id @default(uuid())
  name          String
  email         String?   
  phone         String  @unique
  logoUrl       String?
  primaryColor  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  events        Event[]
  websiteSettings StudioWebsiteSettings?
}

model StudioWebsiteSettings {
  id             String   @id @default(uuid())
  studioId       String   @unique
  featuredEvents Json
  packages       Json
  gallery        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studio         Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

//////////////////////////////////////////////////////
// STUDIO USERS (No Public Signup)
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  phone     String   @unique       // instead of email
  password  String
  role      UserRole @default(STAFF)
  studioId  String

  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// EVENTS (Wedding Events)
//////////////////////////////////////////////////////

model Event {
  id              String    @id @default(uuid())
  studioId        String

  title           String
  brideName       String?
  groomName       String?

  bridePhone      String?
  groomPhone      String?

  coupleAccessToken String  @unique @default(uuid())

  eventDate       DateTime
  location        String?
  googleMapAddress String
  description     String?
  coverImage      String?

  slug            String    @unique
  subdomain       String?   @unique

  isPublished     Boolean   @default(false)
  status          EventStatus @default(DRAFT)
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  archivedAt      DateTime?
  startNotificationSentAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  studio          Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)

  guests          Guest[]
  media           Media[]
  guestInvitations GuestInvitation[]
  bookingRequest  BookingRequest? @relation("BookingRequestHandledEvent")

  @@index([studioId])
}

//////////////////////////////////////////////////////
// GUESTS
//////////////////////////////////////////////////////

model Guest {
  id              String    @id @default(uuid())
  eventId         String
  name            String
  phone           String?
  email           String?
  category        GuestCategory @default(GENERAL)
  invitationCode  String    @unique
  checkedIn       Boolean   @default(false)
  checkedInAt     DateTime?
  createdAt       DateTime  @default(now())

  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitations     GuestInvitation[]

  @@index([eventId])
}

model GuestInvitation {
  id        BigInt            @id @default(autoincrement())
  guestId   String
  eventId   String
  channel   InvitationChannel
  status    String            @default("SENT")
  sentAt    DateTime          @default(now())
  message   String?
  createdAt DateTime          @default(now())

  guest     Guest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([guestId, sentAt])
  @@index([eventId])
}

//////////////////////////////////////////////////////
// MEDIA (POST-EVENT PHOTOS & VIDEOS)
//////////////////////////////////////////////////////

model Media {
  id          String     @id @default(uuid())
  eventId     String
  type        MediaType
  url         String
  groupLabel  String?
  createdAt   DateTime   @default(now())

  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model BookingRequest {
  id           String   @id @default(uuid())
  name         String
  phone        String
  weddingDate  DateTime
  weddingPlace String
  status       BookingRequestStatus @default(NEW)
  handledEventId String? @unique
  handledEvent Event? @relation("BookingRequestHandledEvent", fields: [handledEventId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([weddingDate])
  @@index([status])
}